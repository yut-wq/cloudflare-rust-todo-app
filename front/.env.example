# 環境変数設定例
# このファイルをコピーして .env.local を作成してください

# API Base URL - Rust Worker のエンドポイント
# 開発環境
PUBLIC_API_BASE_URL=http://localhost:8787

# 本番環境での設定例 (デプロイ時に変更)
# PUBLIC_API_BASE_URL=https://my-rust-worker.your-subdomain.workers.dev

# ステージング環境での設定例
# PUBLIC_API_BASE_URL=https://staging.my-rust-worker.your-subdomain.workers.dev

# 使用方法：
# 1. cp .env.example .env.local
# 2. .env.local で PUBLIC_API_BASE_URL を環境に合わせて編集
# 3. pnpm run dev で開発サーバーを起動